  "keyFeatures": [
    "Fully composable compound component API",
    "Automatic filtering and sorting with built-in command-score",
    "Custom filter function support with keyword aliases",
    "Accessible combobox with full ARIA support",
    "Radix UI Dialog integration for modal usage",
    "React 18 safe with useSyncExternalStore",
    "Unstyled with CSS data-attribute selectors for customization",
    "Keyboard navigation with vim bindings support",
    "forceMount prop for persistent items and groups",
    "CSS variable for animated list height (--cmdk-list-height)"
  ],
